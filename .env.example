# Database Connection URL (Connection Pooling for serverless database like Neon, or local database)
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/delivery_app?schema=public"

# Direct Database Connection URL (Used for migrations, e.g. Neon connection string without pooling)
# DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/delivery_app?schema=public"

# JWT Secret Key for Session Authentication (At least 32 characters recommended)
JWT_SECRET="YOUR_JWT_SECRET_KEY"
